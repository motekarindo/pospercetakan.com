---
const navItems = [
  { name: 'Produk', href: '/product' },
  { name: 'Solusi', href: '/solutions' },
  { name: 'Harga', href: '/pricing' },
  { name: 'Tentang', href: '/about-us' },
  { name: 'Blog', href: '/blog' },
];
const whatsappHref =
  'https://wa.me/6281212656699?text=Halo%20pospercetakan.com%20saya%20ingin%20demo%2Fkonsultasi%20terkait%20aplikasi%20POS%20percetakan';
---

<header data-site-header class="site-header sticky top-0 z-50 w-full" role="banner">
  <div class="header-inner mx-auto flex h-[74px] w-full items-center justify-between px-4 md:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-3 transition-transform duration-300 hover:scale-105 focus:scale-105 focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 rounded" aria-label="POS Percetakan home">
      <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-gradient-to-r from-payflo-purple to-payflo-blue text-white font-bold">PP</span>
      <span class="text-lg font-semibold text-payflo-dark">POS Percetakan</span>
    </a>

    <nav class="hidden md:flex items-center space-x-8" role="navigation" aria-label="Main navigation">
      <!-- {navItems.map(item => (
        <a
          href={item.href}
          class="text-gray-700 hover:text-payflo-purple focus:text-payflo-purple transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 rounded px-2 py-1"
        >
          {item.name}
        </a>
      ))} -->
    </nav>

    <div class="flex items-center space-x-4">
      <!-- <a href="/login" class="hidden md:inline-block text-payflo-dark hover:text-payflo-purple focus:text-payflo-purple transition-all duration-300 relative focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 rounded px-2 py-1">
        Masuk
        <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-payflo-purple transition-all duration-300 group-hover:w-full"></span>
      </a> -->
      <a href={whatsappHref} class="btn btn-primary focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2">Minta Demo</a>

      <button
        id="menu-toggle"
        class="md:hidden flex items-center transition-transform duration-300 focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 rounded p-1"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="hidden md:hidden mx-auto mt-2 w-full max-w-6xl rounded-xl border border-gray-200/80 bg-white/95 backdrop-blur-xl shadow-lg" role="navigation" aria-label="Mobile navigation">
    <div class="px-5 py-4 sm:px-6 lg:px-8 space-y-4">
      {navItems.map((item, index) => (
        <a
          href={item.href}
          class="block py-2 px-2 text-gray-700 hover:text-payflo-purple focus:text-payflo-purple transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 rounded"
          style={`transition-delay: ${index * 50}ms;`}
        >
          {item.name}
        </a>
      ))}
      <a href="/login" class="block py-2 px-2 text-gray-700 hover:text-payflo-purple focus:text-payflo-purple transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 rounded">Masuk</a>
    </div>
  </nav>
</header>

<script is:inline>
  const setupHeaderScrollEffect = () => {
    const syncHeaderState = () => {
      const header = document.querySelector('[data-site-header]');
      if (!header) return;
      header.classList.toggle('scrolled', window.scrollY > 12);
    };

    if (!window.__ppHeaderScrollBound) {
      window.addEventListener('scroll', syncHeaderState, { passive: true });
      window.__ppHeaderScrollBound = true;
    }

    syncHeaderState();
  };

  document.addEventListener('astro:page-load', setupHeaderScrollEffect);
</script>
