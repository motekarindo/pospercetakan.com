---
const whatsappHref =
  'https://wa.me/6281212656699?text=Halo%20pospercetakan.com%20saya%20ingin%20demo%2Fkonsultasi%20terkait%20aplikasi%20POS%20percetakan';
---

<section class="py-20 bg-gradient-to-r from-payflo-purple to-payflo-blue text-white relative overflow-hidden">
  <div class="absolute inset-0 overflow-hidden opacity-10">
    <div class="absolute -top-40 -left-40 w-80 h-80 bg-white rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute top-40 -right-20 w-60 h-60 bg-white rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
    <div class="absolute -bottom-40 left-1/3 w-80 h-80 bg-white rounded-full blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
  </div>

  <div class="container-custom relative">
    <div class="max-w-3xl mx-auto text-center animate-on-scroll">
      <h2 class="text-3xl md:text-4xl font-bold">
        Siap Digitalisasi Bisnis Percetakan Anda?
      </h2>
      <p class="mt-6 text-xl opacity-90">
        Gunakan POS Percetakan untuk mengelola order, produksi, dan laporan dalam satu alur kerja yang efisien.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row justify-center gap-4">
        <a href={whatsappHref} class="btn bg-white text-payflo-purple hover:bg-opacity-90 transform transition-all duration-300 hover:scale-105 hover:shadow-lg">
          Mulai Demo
        </a>
        <a href="/documentation" class="btn border border-white hover:bg-white/20 transform transition-all duration-300 hover:scale-105">
          Pelajari Dokumentasi
        </a>
      </div>
    </div>
  </div>
</section>
