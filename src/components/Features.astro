---
import { Icon } from 'astro-icon/components';

const features = [
  {
    title: 'Manajemen Order',
    description: 'Semua pesanan cetak dari customer masuk ke satu sistem lengkap dan terukur.',
    icon: 'ph:wallet-duotone',
    highlights: [
      'Aplikasi POS (Point of Sales) lengkap dan mudah digunakan.',
      // 'Real-time Tracking Order yang bisa diakses oleh Klien.',
      'Buat Quotation dan Invoice otomatis dari Order masuk.',
      'Sistem pembayaran fleksibel. Tunai, Transfer atau QRIS dengan Metode Cicilan.',
    ],
  },
  {
    title: 'Manajemen Stok',
    description: 'Kelola stok bahan mudah terkontrol secara Real-time.',
    icon: 'ph:warehouse-duotone',
    highlights: [
      'Stok keluar otomatis dari Order hingga Produksi',
      'Real-time saldo stok monitoring',
      'Transfer stok bahan baku antar cabang (Coming soon).',
    ],
  },
  {
    title: 'Keuangan & Accounting',
    description: 'Pantau keuangan dan akuntansi otomatis, laporan akurat untuk keputusan bisnis cepat.',
    icon: 'ph:money-wavy',
    highlights: [
      'Pantau laporan dengan mudah lewat dashboard.',
      'Rekap omzet periodik otomatis',
      'Laporan siap export kapan saja',
    ],
  },
  {
    title: 'Manajemen Multi Store ',
    description: 'Kelola multi cabang tanpa pusing dalam satu sistem aplikasi terpusat.',
    icon: 'ph:globe-duotone',
    highlights: [
      'Rekap omzet harian otomatis',
      'Produk terlaris per periode',
      'Laporan siap export kapan saja',
    ],
  },

];
---

<section class="py-20 bg-gradient-to-b from-white to-payflo-gray relative overflow-hidden">
  <div class="absolute inset-0 opacity-5 parallax" data-speed="0.1">
    <div class="absolute inset-0 bg-repeat" style="background-image: url('/grid-pattern.svg');"></div>
  </div>

  <div class="container-custom relative">
    <div class="text-center max-w-3xl mx-auto">
      <h2 class="animate-on-scroll delay-0 text-3xl md:text-4xl font-bold">
          Fitur <span class="gradient-text"> Unggulan POS Percetakan </span>
      </h2>
      <p class="animate-on-scroll delay-1 mt-4 text-xl text-gray-600">
        Dirancang untuk alur kerja percetakan, dari order masuk sampai produk selesai dikirim ke pelanggan.
      </p>
    </div>

    <div class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
      {features.map((feature, index) => (
        <div class={`feature-card animate-on-scroll delay-${index + 2} group`}>
          <div class="h-12 w-12 rounded-lg bg-gradient-to-r from-payflo-purple to-payflo-blue flex items-center justify-center text-white mb-6 transition-transform duration-300 group-hover:scale-110">
            <Icon name={feature.icon} class="h-6 w-6 transition-transform duration-300 group-hover:rotate-12" />
          </div>
          <h3 class="text-xl font-semibold transition-colors duration-300 group-hover:text-payflo-purple">{feature.title}</h3>
          <p class="mt-3 text-gray-600">{feature.description}</p>
          <div class="mt-4 rounded-lg p-4">
            <ul class="space-y-3">
              {feature.highlights.map((item) => (
                <li class="flex items-start gap-2 text-sm text-payflo-dark">
                  <Icon name="ph:check-circle-duotone" class="mt-0.5 h-5 w-5 shrink-0 text-payflo-purple" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
