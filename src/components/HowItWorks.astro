---
const steps = [
  {
    number: '01',
    title: 'Setup Produk & Harga',
    description: 'Input katalog produk cetak, variasi bahan, dan aturan harga sesuai alur bisnis Anda.',
  },
  {
    number: '02',
    title: 'Terima & Proses Order',
    description: 'Kasir langsung mencatat pesanan, pembayaran, dan instruksi produksi tanpa proses manual berulang.',
  },
  {
    number: '03',
    title: 'Monitoring Produksi',
    description: 'Pantau status pekerjaan dari antrean hingga selesai, lalu kirim notifikasi ke pelanggan.',
  },
];
---

<section class="py-20 bg-payflo-gray relative overflow-hidden">
  <div class="absolute inset-0 opacity-5">
    <div class="absolute inset-0 bg-repeat" style="background-image: url('/grid-pattern.svg');"></div>
  </div>

  <div class="container-custom relative">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="animate-on-scroll delay-0 text-3xl md:text-4xl font-bold">Cara Kerja</h2>
      <p class="animate-on-scroll delay-1 mt-4 text-xl text-gray-600">
        Implementasi POS Percetakan dalam tiga langkah sederhana.
      </p>
    </div>

    <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8 relative">
      <div class="hidden md:block absolute top-16 left-1/6 right-1/6 h-0.5 bg-gradient-to-r from-payflo-purple to-payflo-blue"></div>

      {steps.map((step, index) => (
        <div
          class={`bg-white rounded-xl p-8 shadow-lg border border-gray-100 animate-on-scroll delay-${index + 2} group hover:shadow-xl transition-all duration-300 hover:-translate-y-2`}
        >
          <div class="flex items-center justify-center w-12 h-12 rounded-full bg-payflo-purple/10 text-payflo-purple font-semibold transition-all duration-300 group-hover:bg-payflo-purple group-hover:text-white group-hover:scale-110">
            {step.number}
          </div>
          <h3 class="mt-6 text-xl font-semibold transition-colors duration-300 group-hover:text-payflo-purple">{step.title}</h3>
          <p class="mt-3 text-gray-600">{step.description}</p>

          {index < steps.length - 1 && (
            <div class="flex justify-center mt-4 md:hidden">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-payflo-purple animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>

    <div class="mt-16 text-center">
      <div class="animate-on-scroll delay-5">
        <a href="/documentation" class="btn btn-primary group">
          <span class="inline-flex items-center">
            Lihat Dokumentasi
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </span>
        </a>
      </div>
    </div>
  </div>
</section>
